# Praiô Backend — variáveis de ambiente
# Copie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA comite o arquivo .env com dados reais no repositório.

# ── MongoDB ───────────────────────────────────────────────────────────────────
# URI de conexão com o MongoDB Atlas (ou instância local).
# Formato Atlas: mongodb+srv://<usuario>:<senha>@cluster0.xxx.mongodb.net/praio?appName=Cluster0
MONGODB_URI=mongodb+srv://<usuario>:<senha>@cluster0.xxx.mongodb.net/praio?appName=Cluster0

# ── JWT ───────────────────────────────────────────────────────────────────────
# Segredo HMAC-SHA256 (mínimo 32 bytes).
# Gere um seguro com: openssl rand -base64 48
JWT_SECRET=troque-este-valor-por-um-segredo-base64-de-pelo-menos-32-bytes

# Expiração do token em milissegundos.
# 604800000 = 7 dias (padrão)
JWT_EXPIRATION_MS=604800000

# ── CETESB ArcGIS — balneabilidade semanal ────────────────────────────────────
# URL do Feature Layer público da CETESB com a classificação de praias.
# O valor padrão já está correto — só altere se a CETESB mudar a URL.
API_CETESB_ARCGIS_URL=https://arcgis.cetesb.sp.gov.br/server/rest/services/Hosted/Praias/FeatureServer/0

# ── CETESB QUALAR — qualidade do ar ───────────────────────────────────────────
# Crie conta gratuita em: https://qualar.cetesb.sp.gov.br/qualar/home.do
# Sem credenciais, a qualidade do ar retorna null (não derruba a aplicação).
CETESB_USUARIO=seu-usuario-cetesb
CETESB_SENHA=sua-senha-cetesb

# Código da estação CETESB mais próxima de Praia Grande SP:
#   27 = Santos
#   72 = Cubatão-Centro (padrão — mais próxima geograficamente)
# Lista completa: https://qualar.cetesb.sp.gov.br/qualar/home.do → Estações
CETESB_ESTACAO_CODIGO=72

# ── AQICN — qualidade do ar ───────────────────────────────────────────────────
# Token gratuito em: https://aqicn.org/api/
# Sem token, a qualidade do ar via AQICN retorna null (não derruba a aplicação).
AQICN_TOKEN=seu-token-aqicn

# ── Upload de fotos de perfil ─────────────────────────────────────────────────
# Diretório local onde as fotos de perfil dos usuários serão salvas.
# Relativo à raiz do projeto. Padrão: uploads/
UPLOADS_DIR=uploads
